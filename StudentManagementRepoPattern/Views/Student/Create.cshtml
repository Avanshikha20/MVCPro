@model Student
@{
    ViewData["Title"] = "Add Student";
}

<h2 style="text-align:center; margin-bottom:20px;">Add Student</h2>

<div style="width:600px; margin:auto; padding:20px; border:1px solid #ddd; border-radius:6px; background-color:#f9f9f9;">

    <form asp-action="Create" method="post">

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div style="margin-bottom:15px;">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div style="margin-bottom:15px;">
            <label asp-for="Email"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div style="margin-bottom:15px;">
            <label asp-for="Age"></label>
            <input asp-for="Age" class="form-control" />
            <span asp-validation-for="Age" class="text-danger"></span>
        </div>

        <div style="margin-bottom:15px;">
            <label asp-for="Gender"></label>
            <select asp-for="Gender" class="form-control">
                <option value="">Select Gender</option>
                <option>Male</option>
                <option>Female</option>
                <option>Other</option>
            </select>
            <span asp-validation-for="Gender" class="text-danger"></span>
        </div>

        <div style="margin-bottom:15px;">
            <label asp-for="AdmissionDate"></label>
            <input asp-for="AdmissionDate" type="date" class="form-control" />
            <span asp-validation-for="AdmissionDate" class="text-danger"></span>
        </div>

        <div style="margin-bottom:15px;">
            <label asp-for="DepartmentId"></label>
            <select asp-for="DepartmentId" class="form-control" asp-items="@(ViewData["DepartmentId"] as SelectList)">
                <option value="">Select Department</option>
            </select>
            <span asp-validation-for="DepartmentId" class="text-danger"></span>
        </div>

        <div style="margin-bottom:20px;">
            <label asp-for="CourseId"></label>
            <select asp-for="CourseId" class="form-control" asp-items="@(ViewData["CourseId"] as SelectList)">
                <option value="">Select Course</option>
            </select>
            <span asp-validation-for="CourseId" class="text-danger"></span>
        </div>

        <div style="text-align:center;">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}