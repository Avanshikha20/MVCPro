@{
    ViewData["Title"] = "Dashboard";
}

@model DashboardVm

<div class="mb-4">
    <h1 class="h3 mb-1">Corporate Training Institute</h1>
    <div class="text-muted">Student Management Portal (Enterprise Version)</div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted">Total Students</div>
                        <div class="display-6">@Model.TotalStudents</div>
                    </div>
                    <span class="badge bg-primary">Students</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted">Total Departments</div>
                        <div class="display-6">@Model.TotalDepartments</div>
                    </div>
                    <span class="badge bg-success">Departments</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted">Total Courses</div>
                        <div class="display-6">@Model.TotalCourses</div>
                    </div>
                    <span class="badge bg-warning text-dark">Courses</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-3">
                <a class="btn btn-primary w-100" asp-controller="Student" asp-action="Create">Register Student</a>
                <br />
            </div>
            <div class="col-md-3">
                <a class="btn btn-outline-primary w-100" asp-controller="Student" asp-action="Index">Student List</a>
            <br/></div>
            <div class="col-md-3">
                <a class="btn btn-outline-success w-100" asp-controller="Department" asp-action="Index">Manage Departments</a>
            <br/></div>
            <div class="col-md-3">
                <a class="btn btn-outline-warning w-100" asp-controller="Course" asp-action="Index">Manage Courses</a>
            <br/></div>
        </div>
    </div>
</div>
