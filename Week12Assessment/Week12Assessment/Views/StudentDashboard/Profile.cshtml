@model Week12Assessment.ViewModels.StudentProfileViewModel

<h2>Student Profile</h2>

<form asp-action="UpdateProfile">

    <div class="form-group">
        <label>Name</label>
        <input asp-for="StudentName" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label>Email</label>
        <input asp-for="Email" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label>Phone Number</label>
        <input asp-for="PhoneNumber" class="form-control" />
    </div>

    <div class="form-group">
        <label>Address</label>
        <input asp-for="Address" class="form-control" />
    </div>

    <div class="form-group">
        <label>Department</label>
        <input asp-for="DepartmentName" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label>Course</label>
        <input asp-for="CourseName" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label>Course Duration</label>
        <input asp-for="Duration" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label>Course Fees</label>
        <input asp-for="Fees" class="form-control" readonly />
    </div>

    <br />

    <button class="btn btn-success">
        Update Profile
    </button>

    <a asp-controller="StudentDashboard"
       asp-action="Index"
       class="btn btn-secondary">
        Back
    </a>

</form>