@model IEnumerable<Week12Assessment.Models.Student>

<h2>Students</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Add Student</a>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Address</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.StudentName</td>
                <td>@item.Email</td>
                <td>@item.PhoneNumber</td>
                <td>@item.Address</td>

                <td>

                    <a class="btn btn-warning btn-sm"
                       asp-action="Edit"
                       asp-route-id="@item.StudentId">
                        Edit
                    </a>

                    <a class="btn btn-danger btn-sm"
                       asp-action="Delete"
                       asp-route-id="@item.StudentId">
                        Delete
                    </a>

                </td>
            </tr>
        }

    </tbody>

</table>